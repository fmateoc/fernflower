package foreach;

import java.util.Arrays;
import java.util.List;
import java.util.Map;

public class TestGenericForeach {
   public void test1() {
      for(List<String> l : Arrays.asList(Arrays.asList("aString"))) {// 7
         System.out.println(l);// 8
      }

   }// 10

   public void test2(List<Map<String, Object>> list) {
      for(Map<String, Object> m : list) {// 13
         System.out.println(m);// 14
      }

   }// 16

   public void test3(Map<String, Object> map) {
      for(Map.Entry<String, Object> e : map.entrySet()) {// 19
         System.out.println(e);// 20
      }

   }// 22

   public void test4(List<CharSequence> list) {
      for(String s : ((java.lang.Iterable<String>)(java.lang.Iterable)list)) {// 25
         System.out.println(s);// 26
      }

   }// 28
}

