package foreach;

import java.util.List;
import java.util.Map;
import java.util.Set;

public class TestGenericForeach2 {
   public void testRawListStringLoop(List list) {
      for(String s : ((List<String>)list)) {// 7
         System.out.println(s);// 8
      }

   }// 10

   public void testRawMapEntrySetLoop(Map map) {
      for(Map.Entry e : ((Set<Map.Entry>)map.entrySet())) {// 13
         System.out.println(e);// 14
      }

   }// 16
}

